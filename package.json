{
  "name": "productpath",
  "private": true,
  "scripts": {
    "build": "pnpm exec turbo run build",
    "build:api": "pnpm --filter @productpath/api... run build",
    "build:render": "pnpm run db:generate && pnpm run build:api",
    "dev": "pnpm exec turbo run dev --parallel",
    "lint": "pnpm exec turbo run lint",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm exec turbo run test",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "pnpm --filter @productpath/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @productpath/database migrate:deploy",
    "db:push": "pnpm --filter @productpath/database push",
    "db:seed": "pnpm --filter @productpath/database seed",
    "db:studio": "pnpm --filter @productpath/database studio"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
