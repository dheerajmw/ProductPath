# Database — Prisma requires DATABASE_URL (not only POSTGRES_URL)
DATABASE_URL="postgresql://productpath:productpath@localhost:5432/productpath?schema=public"
# Vercel Storage may only show POSTGRES_URL; copy the same value to DATABASE_URL or rely on apps/api alias
# Migrate: use POSTGRES_URL_NON_POOLING as DATABASE_URL → pnpm db:migrate:deploy

# API (apps/api)
API_PORT=4000
API_URL="http://localhost:4000"
# Set on API host when web and API are on different domains (e.g. Vercel + Render)
SESSION_COOKIE_SAMESITE=none
NODE_ENV=development
# Local dev: disable API rate limits (omit or set false in production)
RATE_LIMIT_DISABLED=true
SESSION_SECRET="change-me-to-a-long-random-string"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
# Production (Render): set WEB_APP_URL + CORS_ORIGINS to your Vercel URL.
# All *.vercel.app preview URLs are also allowed automatically in production.
WEB_APP_URL="http://localhost:3000"
ADMIN_APP_URL="http://localhost:3001"

# Seed admin (created on db:seed)
ADMIN_EMAIL="admin@productpath.local"
ADMIN_PASSWORD="changeme-admin"

# Project uploads (local dev)
UPLOAD_DIR="./uploads"

# Internal jobs (optional)
# INTERNAL_API_SECRET="dev-internal-secret"
# VERIFICATION_EXPIRY_POLL=false

# Email (optional — without this, verification links are shown in the UI / API logs in dev)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="ProductPath <onboarding@yourdomain.com>"

# Optional: Sentry
# SENTRY_DSN=

# Next.js apps (local). On Vercel set NEXT_PUBLIC_API_URL in Project → Environment Variables.
NEXT_PUBLIC_API_URL="http://localhost:4000"
