{
  "name": "productpath",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @productpath/database generate",
    "db:migrate": "pnpm --filter @productpath/database migrate:dev",
    "db:push": "pnpm --filter @productpath/database push",
    "db:seed": "pnpm --filter @productpath/database seed",
    "db:studio": "pnpm --filter @productpath/database studio"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
